# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autodm

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Instagram OAuth ───────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/instagram/callback

# ── X (Twitter) OAuth ─────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── AI (optional) ─────────────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────
DEBUG=true
