# ── Root-level combined env (copy to .env) ───
# This file shows all env vars for the full stack.

# ┌─ Frontend (Nuxt 3) ───────────────────────────────────────────────────────
NUXT_PUBLIC_APP_NAME=AutoDM
NUXT_PUBLIC_WS_URL=ws://localhost:8000/ws
FASTAPI_BASE_URL=http://localhost:8000

# ┌─ Backend (FastAPI) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autodm
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change_me_to_a_very_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/instagram/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

OPENAI_API_KEY=

DEBUG=true
